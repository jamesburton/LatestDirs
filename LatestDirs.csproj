<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>LatestDirs</ToolCommandName>
    <PackageId>LatestDirs</PackageId>
    <Authors>James</Authors>
    <Description>A tool to rapidly find recently changed directories.</Description>
    <Version>1.0.0</Version>
    <PublishAot>true</PublishAot>
    <OptimizationPreference>Speed</OptimizationPreference>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.CommandLine" Version="2.0.0-beta4.22272.1" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="Core\**" />
    <Compile Remove="Benchmarks\**" />
    <EmbeddedResource Remove="Core\**" />
    <EmbeddedResource Remove="Benchmarks\**" />
    <None Remove="Core\**" />
    <None Remove="Benchmarks\**" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="Core\LatestDirs.Core.csproj" />
  </ItemGroup>

</Project>




